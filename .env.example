# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env e preencha com suas credenciais

# ============================================
# WhatsApp (Obrigatório apenas no primeiro login)
# ============================================
PHONE_NUMBER=5511999999999

# ============================================
# API Keys (Obrigatório sempre)
# ============================================

# Grok API (X.AI) - Para processamento de imagens
# Obtenha em: https://console.x.ai/
GROK_API_KEY=sua-chave-grok-aqui

# Gemini API (Google) - Para transcrição de áudio
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua-chave-gemini-aqui

# ============================================
# Configurações Opcionais
# ============================================

# Caminho do banco de dados (padrão: ./login/whatsmeow.db)
# DB_PATH=./login/whatsmeow.db
